FROM ubuntu:24.04

RUN apt-get update -y && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        curl ca-certificates git python3 python3-pip python3-pytest bash && \
    curl -fsSL https://deb.nodesource.com/setup_24.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    npm install -g zuplo && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN mkdir -p /home/user && chmod 0755 /home/user

LABEL Author="any-task-builder"
LABEL Description="Zuplo task environment with a newly created project in /home/user/myproject."

RUN cd /home/user && \
    npx -y create-zuplo-api@latest myproject --yes && \
    cd myproject && \
    npm install

# Container contents:
#   - always required libs: curl ca-certificates git python3 python3-pip python3-pytest bash
#   - Node.js v24
#   - zuplo CLI installed globally
#   - /home/user/myproject: standard Zuplo project generated by create-zuplo-api

CMD ["/bin/bash", "-c", "trap : TERM INT; sleep infinity & wait"]
